
#include "vdec.h"

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <fcntl.h>
#include <unistd.h>
#include <errno.h>
#include <sys/ioctl.h>
#include <sys/mman.h>
#include <poll.h>
#include <libavutil/avutil.h>

/* ------------------------------------------------------------------ */
/* Internal helpers                                                     */
/* ------------------------------------------------------------------ */

static int xioctl(int fd, unsigned long request, void *arg)
{
    int r;
    do {
        r = ioctl(fd, request, arg);
    } while (r == -1 && errno == EINTR);
    return r;
}

static int set_output_format(VdecContext *ctx)
{
    struct v4l2_format fmt;
    memset(&fmt, 0, sizeof(fmt));
    fmt.type = V4L2_BUF_TYPE_VIDEO_OUTPUT_MPLANE;
    fmt.fmt.pix_mp.width       = 1920;
    fmt.fmt.pix_mp.height      = 1080;
    fmt.fmt.pix_mp.pixelformat = V4L2_PIX_FMT_H264;
    fmt.fmt.pix_mp.field       = V4L2_FIELD_NONE;
    fmt.fmt.pix_mp.num_planes  = 1;
    fmt.fmt.pix_mp.plane_fmt[0].sizeimage = 1024 * 1024;

    if (xioctl(ctx->fd, VIDIOC_S_FMT, &fmt) < 0) {
        perror("vdec: VIDIOC_S_FMT OUTPUT");
        return -1;
    }
    ctx->out_buf_size = fmt.fmt.pix_mp.plane_fmt[0].sizeimage;
    fprintf(stderr, "vdec: output format set — H264, buf_size=%u\n",
            ctx->out_buf_size);
    return 0;
}

static int alloc_output_buffers(VdecContext *ctx)
{
    struct v4l2_requestbuffers req;
    memset(&req, 0, sizeof(req));
    req.count  = VDEC_OUTPUT_BUFS;
    req.type   = V4L2_BUF_TYPE_VIDEO_OUTPUT_MPLANE;
    req.memory = V4L2_MEMORY_MMAP;

    if (xioctl(ctx->fd, VIDIOC_REQBUFS, &req) < 0) {
        perror("vdec: VIDIOC_REQBUFS OUTPUT");
        return -1;
    }

    for (int i = 0; i < VDEC_OUTPUT_BUFS; i++) {
        struct v4l2_buffer buf;
        struct v4l2_plane  plane;
        memset(&buf,   0, sizeof(buf));
        memset(&plane, 0, sizeof(plane));

        buf.type     = V4L2_BUF_TYPE_VIDEO_OUTPUT_MPLANE;
        buf.memory   = V4L2_MEMORY_MMAP;
        buf.index    = (uint32_t)i;
        buf.m.planes = &plane;
        buf.length   = 1;

        if (xioctl(ctx->fd, VIDIOC_QUERYBUF, &buf) < 0) {
            perror("vdec: VIDIOC_QUERYBUF OUTPUT");
            return -1;
        }

        ctx->out_mem[i] = mmap(NULL,
                               plane.length,
                               PROT_READ | PROT_WRITE,
                               MAP_SHARED,
                               ctx->fd,
                               plane.m.mem_offset);

        if (ctx->out_mem[i] == MAP_FAILED) {
            perror("vdec: mmap OUTPUT");
            return -1;
        }
    }

    fprintf(stderr, "vdec: %d output buffers allocated\n", VDEC_OUTPUT_BUFS);
    return 0;
}

static int stream_off(VdecContext *ctx)
{
    enum v4l2_buf_type type;
    type = V4L2_BUF_TYPE_VIDEO_OUTPUT_MPLANE;
    xioctl(ctx->fd, VIDIOC_STREAMOFF, &type);
    type = V4L2_BUF_TYPE_VIDEO_CAPTURE_MPLANE;
    xioctl(ctx->fd, VIDIOC_STREAMOFF, &type);
    return 0;
}

static int handle_source_change(VdecContext *ctx)
{
    /* Query dimensions WITHOUT touching streaming state */
    struct v4l2_format fmt;
    memset(&fmt, 0, sizeof(fmt));
    fmt.type = V4L2_BUF_TYPE_VIDEO_CAPTURE_MPLANE;
    if (xioctl(ctx->fd, VIDIOC_G_FMT, &fmt) < 0) {
        perror("vdec: VIDIOC_G_FMT");
        return -1;
    }

    uint32_t w = fmt.fmt.pix_mp.width;
    uint32_t h = fmt.fmt.pix_mp.height;

    fprintf(stderr, "vdec: SOURCE_CHANGE — %ux%u\n", w, h);

    if (w <= 32 || h <= 32) {
        /*
         * Driver fires SOURCE_CHANGE immediately on OUTPUT STREAMON
         * before parsing any SPS. Ignore it completely.
         * Do NOT touch capture streaming — that triggers another event.
         */
        fprintf(stderr, "vdec: ignoring pre-SPS SOURCE_CHANGE\n");
        return 0;
    }

    /*
     * Real dimensions — driver has parsed the SPS.
     * Now safe to set up the capture side.
     */
    fprintf(stderr, "vdec: setting up capture at %ux%u\n", w, h);

    /* Stop capture if somehow already running */
    enum v4l2_buf_type type = V4L2_BUF_TYPE_VIDEO_CAPTURE_MPLANE;
    xioctl(ctx->fd, VIDIOC_STREAMOFF, &type);

    /* Close any existing DMABUF fds */
    for (int i = 0; i < VDEC_CAPTURE_BUFS; i++) {
        if (ctx->cap_dmabuf_fd[i] > 0) {
            close(ctx->cap_dmabuf_fd[i]);
            ctx->cap_dmabuf_fd[i] = -1;
        }
    }

    /* Free existing kernel capture buffers */
    struct v4l2_requestbuffers req;
    memset(&req, 0, sizeof(req));
    req.count  = 0;
    req.type   = V4L2_BUF_TYPE_VIDEO_CAPTURE_MPLANE;
    req.memory = V4L2_MEMORY_MMAP;
    xioctl(ctx->fd, VIDIOC_REQBUFS, &req);

    /* Set NV12 at real dimensions */
    memset(&fmt, 0, sizeof(fmt));
    fmt.type = V4L2_BUF_TYPE_VIDEO_CAPTURE_MPLANE;
    fmt.fmt.pix_mp.pixelformat = V4L2_PIX_FMT_NV12;
    fmt.fmt.pix_mp.num_planes  = 1;

    if (xioctl(ctx->fd, VIDIOC_S_FMT, &fmt) < 0) {
        perror("vdec: VIDIOC_S_FMT CAPTURE");
        return -1;
    }

    ctx->width        = fmt.fmt.pix_mp.width;
    ctx->height       = fmt.fmt.pix_mp.height;
    ctx->cap_buf_size = fmt.fmt.pix_mp.plane_fmt[0].sizeimage;

    fprintf(stderr, "vdec: capture format — NV12 %ux%u buf_size=%u\n",
            ctx->width, ctx->height, ctx->cap_buf_size);

    /* Allocate capture buffers */
    memset(&req, 0, sizeof(req));
    req.count  = VDEC_CAPTURE_BUFS;
    req.type   = V4L2_BUF_TYPE_VIDEO_CAPTURE_MPLANE;
    req.memory = V4L2_MEMORY_MMAP;

    if (xioctl(ctx->fd, VIDIOC_REQBUFS, &req) < 0) {
        perror("vdec: VIDIOC_REQBUFS CAPTURE");
        return -1;
    }

    for (int i = 0; i < VDEC_CAPTURE_BUFS; i++) {
        struct v4l2_buffer buf;
        struct v4l2_plane  plane;
        memset(&buf,   0, sizeof(buf));
        memset(&plane, 0, sizeof(plane));

        buf.type     = V4L2_BUF_TYPE_VIDEO_CAPTURE_MPLANE;
        buf.memory   = V4L2_MEMORY_MMAP;
        buf.index    = (uint32_t)i;
        buf.m.planes = &plane;
        buf.length   = 1;

        if (xioctl(ctx->fd, VIDIOC_QUERYBUF, &buf) < 0) {
            perror("vdec: VIDIOC_QUERYBUF CAPTURE");
            return -1;
        }

        /* Export as DMABUF fd — handed directly to DRM later */
        struct v4l2_exportbuffer expbuf;
        memset(&expbuf, 0, sizeof(expbuf));
        expbuf.type  = V4L2_BUF_TYPE_VIDEO_CAPTURE_MPLANE;
        expbuf.index = (uint32_t)i;
        expbuf.plane = 0;
        expbuf.flags = O_RDONLY;

        if (xioctl(ctx->fd, VIDIOC_EXPBUF, &expbuf) < 0) {
            perror("vdec: VIDIOC_EXPBUF");
            return -1;
        }
        ctx->cap_dmabuf_fd[i] = expbuf.fd;

        /* Queue buffer so decoder can fill it */
        memset(&plane, 0, sizeof(plane));
        buf.m.planes = &plane;
        if (xioctl(ctx->fd, VIDIOC_QBUF, &buf) < 0) {
            perror("vdec: VIDIOC_QBUF CAPTURE");
            return -1;
        }
    }

    /* Start capture streaming */
    if (xioctl(ctx->fd, VIDIOC_STREAMON, &type) < 0) {
        perror("vdec: VIDIOC_STREAMON CAPTURE");
        return -1;
    }

    fprintf(stderr, "vdec: %d capture buffers ready, streaming started\n",
            VDEC_CAPTURE_BUFS);

    ctx->fmt_negotiated = 1;
    return 0;
}

/* ------------------------------------------------------------------ */
/* Feed one Annex B packet to the V4L2 output queue                    */
/* ------------------------------------------------------------------ */

static int feed_packet(VdecContext *ctx, int buf_idx, AVPacket *pkt)
{
    uint32_t copy_size = (uint32_t)pkt->size;
    if (copy_size > ctx->out_buf_size)
        copy_size = ctx->out_buf_size;
    memcpy(ctx->out_mem[buf_idx], pkt->data, copy_size);

    struct v4l2_buffer buf;
    struct v4l2_plane  plane;
    memset(&buf,   0, sizeof(buf));
    memset(&plane, 0, sizeof(plane));

    buf.type              = V4L2_BUF_TYPE_VIDEO_OUTPUT_MPLANE;
    buf.memory            = V4L2_MEMORY_MMAP;
    buf.index             = (uint32_t)buf_idx;
    buf.m.planes          = &plane;
    buf.length            = 1;
    buf.field             = V4L2_FIELD_NONE;
    buf.timestamp.tv_sec  = (long)(pkt->pts / 1000000LL);
    buf.timestamp.tv_usec = (long)(pkt->pts % 1000000LL);
    plane.bytesused       = copy_size;
    plane.length          = ctx->out_buf_size;

    if (xioctl(ctx->fd, VIDIOC_QBUF, &buf) < 0) {
        perror("vdec: VIDIOC_QBUF OUTPUT");
        return -1;
    }
    return 0;
}

/* ------------------------------------------------------------------ */
/* Public API                                                           */
/* ------------------------------------------------------------------ */

int vdec_open(VdecContext *ctx, AVStream *stream,
              Queue *packet_queue, Queue *frame_queue)
{
    memset(ctx, 0, sizeof(*ctx));
    ctx->packet_queue = packet_queue;
    ctx->frame_queue  = frame_queue;

    for (int i = 0; i < VDEC_CAPTURE_BUFS; i++)
        ctx->cap_dmabuf_fd[i] = -1;

    /* ----------------------------------------------------------------
     * Initialise h264_mp4toannexb BSF
     * MP4 stores H264 in AVCC format (length-prefixed NALs).
     * bcm2835-codec expects Annex B (start-code prefixed NALs).
     * ---------------------------------------------------------------- */
    const AVBitStreamFilter *bsf_filter =
        av_bsf_get_by_name("h264_mp4toannexb");
    if (!bsf_filter) {
        fprintf(stderr, "vdec: FATAL — h264_mp4toannexb BSF not found\n");
        return -1;
    }

    if (av_bsf_alloc(bsf_filter, &ctx->bsf) < 0) {
        fprintf(stderr, "vdec: FATAL — failed to alloc BSF\n");
        return -1;
    }

    if (avcodec_parameters_copy(ctx->bsf->par_in, stream->codecpar) < 0) {
        fprintf(stderr, "vdec: FATAL — failed to copy params to BSF\n");
        return -1;
    }
    ctx->bsf->time_base_in = stream->time_base;

    if (av_bsf_init(ctx->bsf) < 0) {
        fprintf(stderr, "vdec: FATAL — failed to init BSF\n");
        return -1;
    }

    fprintf(stderr, "vdec: h264_mp4toannexb BSF initialised\n");

    /* ----------------------------------------------------------------
     * Open /dev/video10 — hard fail if unavailable
     * ---------------------------------------------------------------- */
    ctx->fd = open("/dev/video10", O_RDWR | O_NONBLOCK);
    if (ctx->fd < 0) {
        perror("vdec: cannot open /dev/video10");
        fprintf(stderr, "vdec: FATAL — hardware decode unavailable\n");
        return -1;
    }

    struct v4l2_capability cap;
    if (xioctl(ctx->fd, VIDIOC_QUERYCAP, &cap) < 0) {
        perror("vdec: VIDIOC_QUERYCAP");
        return -1;
    }

    if (!(cap.capabilities & V4L2_CAP_VIDEO_M2M_MPLANE)) {
        fprintf(stderr, "vdec: FATAL — device is not M2M multiplanar\n");
        return -1;
    }

    fprintf(stderr, "vdec: opened %s (%s)\n", cap.card, cap.driver);

    /* Subscribe to SOURCE_CHANGE */
    struct v4l2_event_subscription sub;
    memset(&sub, 0, sizeof(sub));
    sub.type = V4L2_EVENT_SOURCE_CHANGE;
    if (xioctl(ctx->fd, VIDIOC_SUBSCRIBE_EVENT, &sub) < 0) {
        perror("vdec: VIDIOC_SUBSCRIBE_EVENT SOURCE_CHANGE");
        return -1;
    }

    if (set_output_format(ctx)    < 0) return -1;
    if (alloc_output_buffers(ctx) < 0) return -1;

    /*
     * Start OUTPUT streaming only.
     * Do NOT touch capture side here — the driver fires SOURCE_CHANGE
     * immediately if capture is started before packets are fed.
     * We wait for SOURCE_CHANGE with real dimensions instead.
     */
    enum v4l2_buf_type type = V4L2_BUF_TYPE_VIDEO_OUTPUT_MPLANE;
    if (xioctl(ctx->fd, VIDIOC_STREAMON, &type) < 0) {
        perror("vdec: VIDIOC_STREAMON OUTPUT");
        return -1;
    }

    fprintf(stderr, "vdec: output streaming started — waiting for SPS\n");
    return 0;
}

/* ------------------------------------------------------------------ */

void vdec_run(VdecContext *ctx)
{
    int out_buf_free[VDEC_OUTPUT_BUFS];
    for (int i = 0; i < VDEC_OUTPUT_BUFS; i++)
        out_buf_free[i] = 1;

    int eos       = 0;
    int eos_polls = 0;

    struct pollfd pfd;
    pfd.fd     = ctx->fd;
    pfd.events = POLLIN | POLLPRI;

    while (1) {
        /* ---------------------------------------------------------- */
        /* 1. Reclaim OUTPUT buffers the driver finished with          */
        /* ---------------------------------------------------------- */
        {
            struct v4l2_buffer buf;
            struct v4l2_plane  plane;
            while (1) {
                memset(&buf,   0, sizeof(buf));
                memset(&plane, 0, sizeof(plane));
                buf.type     = V4L2_BUF_TYPE_VIDEO_OUTPUT_MPLANE;
                buf.memory   = V4L2_MEMORY_MMAP;
                buf.m.planes = &plane;
                buf.length   = 1;
                if (xioctl(ctx->fd, VIDIOC_DQBUF, &buf) < 0)
                    break;
                out_buf_free[buf.index] = 1;
            }
        }

        /* ---------------------------------------------------------- */
        /* 2. Feed Annex B packets into free OUTPUT buffers            */
        /* ---------------------------------------------------------- */
        if (!eos) {
            for (int i = 0; i < VDEC_OUTPUT_BUFS; i++) {
                if (!out_buf_free[i]) continue;

                void *item = NULL;
                if (!queue_pop(ctx->packet_queue, &item)) {
                    fprintf(stderr, "vdec: end of stream\n");
                    eos = 1;
                    break;
                }
                AVPacket *raw_pkt = (AVPacket *)item;

                /* Convert AVCC → Annex B via BSF */
                if (av_bsf_send_packet(ctx->bsf, raw_pkt) < 0) {
                    av_packet_free(&raw_pkt);
                    continue;
                }
                av_packet_free(&raw_pkt);

                AVPacket *annexb_pkt = av_packet_alloc();
                if (!annexb_pkt) continue;

                if (av_bsf_receive_packet(ctx->bsf, annexb_pkt) < 0) {
                    av_packet_free(&annexb_pkt);
                    continue;
                }

                out_buf_free[i] = 0;
                int err = feed_packet(ctx, i, annexb_pkt);
                av_packet_free(&annexb_pkt);

                if (err < 0)
                    out_buf_free[i] = 1;
            }
        }

        /* ---------------------------------------------------------- */
        /* 3. Poll for decoded frames (POLLIN) and events (POLLPRI)    */
        /* ---------------------------------------------------------- */
        int ret = poll(&pfd, 1, 100);
        if (ret < 0) {
            if (errno == EINTR) continue;
            perror("vdec: poll");
            break;
        }

        /* ---------------------------------------------------------- */
        /* 4. Handle SOURCE_CHANGE — fires once driver has parsed SPS  */
        /* ---------------------------------------------------------- */
        if (pfd.revents & POLLPRI) {
            struct v4l2_event evt;
            memset(&evt, 0, sizeof(evt));
            if (xioctl(ctx->fd, VIDIOC_DQEVENT, &evt) == 0) {
                if (evt.type == V4L2_EVENT_SOURCE_CHANGE) {
                    if (handle_source_change(ctx) < 0) {
                        fprintf(stderr, "vdec: source change handling failed\n");
                        break;
                    }
                }
            }
        }

        /* ---------------------------------------------------------- */
        /* 5. Dequeue decoded frames                                   */
        /* ---------------------------------------------------------- */
        if ((pfd.revents & POLLIN) && ctx->fmt_negotiated) {
            while (1) {
                struct v4l2_buffer buf;
                struct v4l2_plane  plane;
                memset(&buf,   0, sizeof(buf));
                memset(&plane, 0, sizeof(plane));
                buf.type     = V4L2_BUF_TYPE_VIDEO_CAPTURE_MPLANE;
                buf.memory   = V4L2_MEMORY_MMAP;
                buf.m.planes = &plane;
                buf.length   = 1;

                if (xioctl(ctx->fd, VIDIOC_DQBUF, &buf) < 0)
                    break;

                DecodedFrame *frame = malloc(sizeof(DecodedFrame));
                if (!frame) {
                    xioctl(ctx->fd, VIDIOC_QBUF, &buf);
                    continue;
                }

                frame->dmabuf_fd = ctx->cap_dmabuf_fd[buf.index];
                frame->buf_index = (int)buf.index;
                frame->width     = ctx->width;
                frame->height    = ctx->height;
                frame->pts_us    = (int64_t)buf.timestamp.tv_sec  * 1000000LL
                                 + (int64_t)buf.timestamp.tv_usec;

                if (!queue_push(ctx->frame_queue, frame)) {
                    free(frame);
                    goto done;
                }
            }
        }

        /* ---------------------------------------------------------- */
        /* 6. After EOS drain remaining frames then exit               */
        /* ---------------------------------------------------------- */
        if (eos) {
            if (++eos_polls > 20)
                break;
        }
    }

done:
    queue_flush(ctx->frame_queue);
}

/* ------------------------------------------------------------------ */

void vdec_requeue_frame(VdecContext *ctx, DecodedFrame *frame)
{
    struct v4l2_buffer buf;
    struct v4l2_plane  plane;
    memset(&buf,   0, sizeof(buf));
    memset(&plane, 0, sizeof(plane));

    buf.type     = V4L2_BUF_TYPE_VIDEO_CAPTURE_MPLANE;
    buf.memory   = V4L2_MEMORY_MMAP;
    buf.index    = (uint32_t)frame->buf_index;
    buf.m.planes = &plane;
    buf.length   = 1;

    xioctl(ctx->fd, VIDIOC_QBUF, &buf);
    free(frame);
}

/* ------------------------------------------------------------------ */

void vdec_close(VdecContext *ctx)
{
    stream_off(ctx);

    if (ctx->bsf) {
        av_bsf_free(&ctx->bsf);
        ctx->bsf = NULL;
    }

    for (int i = 0; i < VDEC_CAPTURE_BUFS; i++) {
        if (ctx->cap_dmabuf_fd[i] > 0) {
            close(ctx->cap_dmabuf_fd[i]);
            ctx->cap_dmabuf_fd[i] = -1;
        }
    }

    for (int i = 0; i < VDEC_OUTPUT_BUFS; i++) {
        if (ctx->out_mem[i] && ctx->out_mem[i] != MAP_FAILED) {
            munmap(ctx->out_mem[i], ctx->out_buf_size);
            ctx->out_mem[i] = NULL;
        }
    }

    if (ctx->fd >= 0) {
        close(ctx->fd);
        ctx->fd = -1;
    }
}
